{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LobbySequenceConfig",
  "type": "object",
  "required": ["id", "globalLives", "phases", "lobbyWinCondition"],
  "properties": {
    "id": { "type": "string" },
    "globalLives": { "type": "integer", "minimum": 1 },
    "phases": {
      "type": "array",
      "items": { "$ref": "#/definitions/SequencePhase" }
    },
    "lobbyWinCondition": { "$ref": "#/definitions/LobbyWinCondition" }
  },

  "definitions": {
    "SequencePhase": {
      "oneOf": [
        { "$ref": "#/definitions/WaitPhase" },
        { "$ref": "#/definitions/GamePhase" },
        { "$ref": "#/definitions/LoopPhase" },
        { "$ref": "#/definitions/EndPhase" }
      ]
    },

    "WaitPhase": {
      "type": "object",
      "required": ["type", "id", "waitFor", "quorum"],
      "properties": {
        "type":      { "type": "string", "const": "wait" },
        "id":        { "type": "string" },
        "waitFor":   { "type": "string", "description": "Client message type to collect" },
        "quorum":    {
          "oneOf": [
            { "type": "integer", "minimum": 1, "description": "Absolute player count" },
            { "type": "string",  "pattern": "^[0-9]+%$", "description": "Percentage e.g. 80%" }
          ]
        },
        "timeout":   { "type": "integer", "minimum": 0, "description": "Seconds; 0 = no timeout" },
        "onTimeout": { "type": "string", "enum": ["proceed", "random"] }
      }
    },

    "GamePhase": {
      "type": "object",
      "required": ["type", "id", "gameModeSelect", "elimination"],
      "properties": {
        "type":           { "type": "string", "const": "game" },
        "id":             { "type": "string" },
        "gameModeSelect": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/GameModeSelectEntry" }
        },
        "elimination": { "$ref": "#/definitions/EliminationRule" }
      }
    },

    "LoopPhase": {
      "type": "object",
      "required": ["type", "id", "repeat", "phases"],
      "properties": {
        "type":   { "type": "string", "const": "loop" },
        "id":     { "type": "string" },
        "repeat": { "type": "string", "enum": ["until_lobby_end"] },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/definitions/SequencePhase" }
        }
      }
    },

    "EndPhase": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string", "const": "end" },
        "id":   { "type": "string" }
      }
    },

    "GameModeSelectEntry": {
      "type": "object",
      "required": ["condition", "pick", "candidates"],
      "properties": {
        "condition":  { "type": "string", "description": "Expression: 'activePlayers > 30' or 'true'" },
        "pick":       { "type": "string", "enum": ["random", "fixed"] },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/GameModeCandidate" }
        }
      }
    },

    "GameModeCandidate": {
      "type": "object",
      "required": ["modeId", "winCondition"],
      "properties": {
        "modeId":       { "type": "string" },
        "winCondition": { "$ref": "#/definitions/WinCondition" }
      }
    },

    "WinCondition": {
      "oneOf": [
        { "$ref": "#/definitions/WinConditionQuorumWin" },
        { "$ref": "#/definitions/WinConditionTimerSurvival" }
      ]
    },

    "WinConditionQuorumWin": {
      "type": "object",
      "required": ["type", "trigger", "quorum"],
      "properties": {
        "type":    { "type": "string", "const": "quorum_win" },
        "trigger": { "type": "string", "description": "Client PHASE_EVENT.event value" },
        "quorum":  {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string",  "pattern": "^[0-9]+%$" }
          ]
        }
      }
    },

    "WinConditionTimerSurvival": {
      "type": "object",
      "required": ["type", "duration", "loseTrigger"],
      "properties": {
        "type":         { "type": "string", "const": "timer_survival" },
        "duration":     { "type": "integer", "minimum": 1, "description": "Seconds" },
        "loseTrigger":  { "type": "string", "description": "Client PHASE_EVENT.event value for elimination" }
      }
    },

    "EliminationRule": {
      "type": "object",
      "required": ["livesLost"],
      "properties": {
        "livesLost": { "type": "integer", "minimum": 1 }
      }
    },

    "LobbyWinCondition": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "type": "string", "const": "last_with_lives" } }
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "type": "string", "const": "best_cumulative_score" } }
        },
        {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type":  { "type": "string", "const": "fixed_rounds" },
            "value": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    }
  }
}
