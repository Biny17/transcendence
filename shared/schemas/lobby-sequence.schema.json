{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LobbySequenceConfig",
  "description": "Phase-based lobby orchestration configuration",
  "definitions": {
    "WinConditionQuorumWin": {
      "type": "object",
      "properties": {
        "type": { "const": "quorum_win" },
        "trigger": { "type": "string" },
        "quorum": { "oneOf": [{ "type": "number" }, { "type": "string", "pattern": "^[0-9]+%$" }] }
      },
      "required": ["type", "trigger", "quorum"],
      "additionalProperties": false
    },
    "WinConditionTimerSurvival": {
      "type": "object",
      "properties": {
        "type": { "const": "timer_survival" },
        "duration": { "type": "number", "minimum": 1 },
        "loseTrigger": { "type": "string" }
      },
      "required": ["type", "duration", "loseTrigger"],
      "additionalProperties": false
    },
    "WinCondition": {
      "oneOf": [
        { "$ref": "#/definitions/WinConditionQuorumWin" },
        { "$ref": "#/definitions/WinConditionTimerSurvival" }
      ]
    },
    "EliminationRule": {
      "type": "object",
      "properties": {
        "livesLost": { "type": "number", "minimum": 0 }
      },
      "required": ["livesLost"],
      "additionalProperties": false
    },
    "GameModeCandidate": {
      "type": "object",
      "properties": {
        "worldId": { "type": "string" },
        "cinematic": { "type": "boolean" },
        "loadTimeout": { "type": "number", "minimum": 1 },
        "winCondition": { "$ref": "#/definitions/WinCondition" },
        "elimination": { "$ref": "#/definitions/EliminationRule" }
      },
      "required": ["worldId", "winCondition", "elimination"],
      "additionalProperties": false
    },
    "GameModeSelectEntry": {
      "type": "object",
      "properties": {
        "condition": { "type": "string" },
        "pick": { "enum": ["random", "fixed"] },
        "candidates": {
          "type": "array",
          "items": { "$ref": "#/definitions/GameModeCandidate" },
          "minItems": 1
        }
      },
      "required": ["condition", "pick", "candidates"],
      "additionalProperties": false
    },
    "CinematicPhase": {
      "type": "object",
      "properties": {
        "type": { "const": "cinematic" },
        "id": { "type": "string" },
        "timeout": { "type": "number", "minimum": 0 }
      },
      "required": ["type", "id", "timeout"],
      "additionalProperties": false
    },
    "WaitPhase": {
      "type": "object",
      "properties": {
        "type": { "const": "wait" },
        "worldId": { "type": "string" },
        "waitFor": { "type": "string", "enum": ["PLAYER_READY", "WORLD_LOADED"] },
        "quorum": { "oneOf": [{ "type": "number" }, { "type": "string", "pattern": "^[0-9]+%$" }] },
        "timeout": { "type": "number", "minimum": 0 },
        "onTimeout": { "enum": ["proceed", "random"] }
      },
      "required": ["type", "worldId", "waitFor", "quorum", "timeout"],
      "additionalProperties": false
    },
    "GamePhase": {
      "type": "object",
      "properties": {
        "type": { "const": "game" },
        "sendGameResult": { "type": "boolean" },
        "endCondition": { "$ref": "#/definitions/LobbyWinCondition" },
        "gameModeSelect": {
          "type": "array",
          "items": { "$ref": "#/definitions/GameModeSelectEntry" },
          "minItems": 1
        },
        "elimination": { "$ref": "#/definitions/EliminationRule" }
      },
      "required": ["type", "sendGameResult", "gameModeSelect", "elimination"],
      "additionalProperties": false
    },
    "LoopPhase": {
      "type": "object",
      "properties": {
        "type": { "const": "loop" },
        "id": { "type": "string" },
        "repeat": { "const": "until_lobby_end" },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/definitions/SequencePhase" },
          "minItems": 1
        }
      },
      "required": ["type", "id", "repeat", "phases"],
      "additionalProperties": false
    },
    "EndPhase": {
      "type": "object",
      "properties": {
        "type": { "const": "end" },
        "worldId": { "type": "string" },
        "timeout": { "type": "number", "minimum": 0 }
      },
      "required": ["type", "worldId", "timeout"],
      "additionalProperties": false
    },
    "SequencePhase": {
      "oneOf": [
        { "$ref": "#/definitions/WaitPhase" },
        { "$ref": "#/definitions/GamePhase" },
        { "$ref": "#/definitions/LoopPhase" },
        { "$ref": "#/definitions/EndPhase" },
        { "$ref": "#/definitions/CinematicPhase" }
      ]
    },
    "LobbyWinCondition": {
      "oneOf": [
        { "type": "object", "properties": { "type": { "const": "last_with_lives" } }, "required": ["type"], "additionalProperties": false },
        { "type": "object", "properties": { "type": { "const": "best_cumulative_score" } }, "required": ["type"], "additionalProperties": false },
        { "type": "object", "properties": { "type": { "const": "fixed_rounds" }, "value": { "type": "number", "minimum": 1 } }, "required": ["type", "value"], "additionalProperties": false }
      ]
    },
    "LobbySequenceConfig": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "globalLives": { "type": "number", "minimum": 0 },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/definitions/SequencePhase" },
          "minItems": 1
        },
        "lobbyWinCondition": { "$ref": "#/definitions/LobbyWinCondition" }
      },
      "required": ["id", "globalLives", "phases", "lobbyWinCondition"],
      "additionalProperties": false
    }
  },
  "$ref": "#/definitions/LobbySequenceConfig"
}
