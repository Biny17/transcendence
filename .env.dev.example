# ========================
# Infrastructure
# ========================

# --- API Server (Backend) for frontend and game server
API_PROTOCOL=http
API_HOST=localhost
API_PORT=8080

# --- Frontend (Next.js) for api origins
FRONT_PROTOCOL=http
FRONT_HOST=localhost
FRONT_PORT=3001

# --- Game Server (WebSocket) for web client to connect
GAME_SERVER_PROTOCOL=ws
GAME_SERVER_HOST=localhost
GAME_SERVER_PORT=3002

# --- Database (PostgreSQL)
DB_PORT=5432
DB_HOST=db #only used by backend

# ========================
# Database Credentials
# ========================
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=myappdb

# ========================
# API Server Security
# ========================
JWT_SECRET=rvB4NTMMi0PeVsP3Xwomj87VOMdJDyiityvYQiNmx6vWv0R4tADQVbOisIzG4e4x
KEYPATH=./secret/private.pem

# --- Mail Service (Gmail)
GMAIL_ADDRESS=tristanbiny.lod@gmail.com
