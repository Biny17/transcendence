# ========================
# Infrastructure
# ========================

# --- API Server (Backend) for frontend and game server
API_PROTOCOL=https
API_HOST=api.domain.com
API_PORT=8080

# --- Frontend (Next.js) for api origins
FRONT_PROTOCOL=https
FRONT_HOST=front.domain.com
FRONT_PORT=3001

# --- Game Server (WebSocket) for web client to connect
GAME_SERVER_PROTOCOL=wss
GAME_SERVER_HOST=ws.domain.com
GAME_SERVER_PORT=3002

# --- Database (PostgreSQL)
DB_PORT=5432
DB_HOST=db #only used by backend

# ========================
# Database Credentials
# ========================
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=myappdb

# ========================
# API Server Security
# ========================
JWT_SECRET=your_jwt_secret_here # openssl rand -hex 32
KEYPATH=./secret/private.pem

# --- Mail Service (Gmail)
GMAIL_ADDRESS=tristanbiny.lod@gmail.com
GMAIL_PASSWORD=fjtsemuidbjwncpi

# ========================
# Cookies (Frontend Domain)
# ========================
# Use parent domain (cookie works on all subdomains)
COOKIE_DOMAIN=domain.com

# ========================
# Game Server
# ========================
LOBBY_CONFIG=one_game

# ========================
# Development Mode
# ========================
# Set LOCAL=1 when developing on localhost to include port in URLs.
# LOCAL=1