# ========================
# Infrastructure
# ========================

# --- API Server (Backend) for frontend and game server
API_PROTOCOL=http
API_HOST=localhost
API_PORT=8080

# --- Frontend (Next.js) for api origins
FRONT_PROTOCOL=http
FRONT_HOST=localhost
FRONT_PORT=3001

# --- Game Server (WebSocket) for web client to connect
GAME_SERVER_PROTOCOL=ws
GAME_SERVER_HOST=localhost 
GAME_SERVER_PORT=3002

# --- Database (PostgreSQL)
DB_PORT=5432
DB_HOST=localhost #only used by backend

# ========================
# Database Credentials
# ========================
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=myappdb

# ========================
# API Server Security
# ========================
JWT_SECRET=rvB4NTMMi0PeVsP3Xwomj87VOMdJDyiityvYQiNmx6vWv0R4tADQVbOisIzG4e4x
KEYPATH=./secret/private.pem
CREDENTIAL=rvB4NTMMi0PeVsP3Xwom

# --- Mail Service (Gmail)
GMAIL_ADDRESS=tristanbiny.lod@gmail.com
GMAIL_PASSWORD=fjtsemuidbjwncpi

# ========================
# Game Server
# ========================
LOBBY_CONFIG=one_game

# ========================
# Cookies (Frontend Domain)
# ========================
# Use "localhost" for local development (cookie will be host-only, no secure flag)
# Use your domain (e.g., "spacecowboy.fr") for production with HTTPS (cookie works across subdomains)
# Leave empty to omit Domain attribute entirely
COOKIE_DOMAIN=localhost

# ========================
# Development Mode
# ========================
# Set LOCAL=1 when developing on localhost to include port in URLs.
# Leave unset when using Cloudflare tunnel (port handled by tunnel, not in URL).
LOCAL=1